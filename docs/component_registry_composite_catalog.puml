@startuml ComponentRegistry_CompositeCatalog
!theme plain
left to right direction
skinparam linetype ortho
skinparam shadowing false
skinparam defaultFontSize 11
skinparam classAttributeIconSize 0
skinparam nodesep 80
skinparam ranksep 80
hide empty members

skinparam package {
    BorderColor #455A64
    FontStyle bold
}

skinparam class {
    BorderColor #424242
    BackgroundColor #FAFAFA
    BackgroundColor<<User>> #FFF3E0
    BackgroundColor<<Config>> #E3F2FD
    BackgroundColor<<Registry>> #F3E5F5
    BackgroundColor<<Catalog>> #E8F5E9
    BackgroundColor<<Upstream>> #ECEFF1
    BackgroundColor<<Product>> #FFF8E1
}

skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
    FontSize 10
}

title ComponentRegistry + CompositeCatalog 组件注册与装配流程

package "1. 用户侧" {
    class "用户代码" as UserCode <<User>> {
        + register_* 装饰器
        + framework_models(...)
    }
}

package "2. rlframework 注册与配置" {
    class ComponentRegistry <<Registry>> {
        {static} register_*(name)
        {static} get_*(name)
        {static} _registered_builders
    }

    class "CustomPPOConfig / CustomSACConfig" as CustomConfig <<Config>> {
        + framework_models(...)
        + model_config._framework_custom_config
        + RLModuleSpec.catalog_class
    }
}

package "3. RLlib 构建入口" {
    class RLModuleSpec <<Upstream>> {
        + catalog_class
        + model_config
    }

    class RLModule <<Upstream>> {
        + catalog.build_*()
    }
}

package "4. CompositeCatalog 适配层" {
    class "PPO / SAC / DQN CompositeCatalog" as CompositeCatalog <<Catalog>> {
        + build_encoder(...)
        + build_head(...)
        + default -> super().build(...)
    }

    class "PPO / SAC / DQN Catalog" as RLlibCatalog <<Upstream>>
}

package "5. 最终网络组件" {
    class "Encoder / Head 实例" as NetworkComponent <<Product>> {
        + 自定义组件
        + RLlib 默认组件
    }
}

UserCode --> ComponentRegistry : 1. register_*\nname -> builder
UserCode --> CustomConfig : 2. framework_models\n选择组件名
CustomConfig --> RLModuleSpec : 3. 写入配置\n切换 catalog_class
RLModuleSpec --> RLModule : 4. 创建 RLModule
RLModule --> CompositeCatalog : 5. build_encoder / build_head
CompositeCatalog --> ComponentRegistry : 6. get_* 查 builder
CompositeCatalog --> NetworkComponent : 7. 命中自定义\n否则默认组件
CompositeCatalog --|> RLlibCatalog : 继承并 fallback

note bottom of CompositeCatalog
    关键分支：先按 _framework_custom_config 到 ComponentRegistry 查 builder；
    查到就构建自定义组件，default 或未注册则调用 RLlib 原生 Catalog。
end note

legend right
    主链路只保留 7 步，具体 PPO / SAC / DQN 的方法差异收敛到 CompositeCatalog 内部。
endlegend

@enduml
